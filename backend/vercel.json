{
  "version": 2,
  "name": "arcperpx-backend",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "src/index.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/index.ts"
    },
    {
      "src": "/health",
      "dest": "src/index.ts"
    }
  ]
}
